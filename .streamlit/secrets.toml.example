# ─────────────────────────────────────────────────────────────────────────
# secrets.toml.example
# ─────────────────────
# Copy this file to ".streamlit/secrets.toml" (remove ".example") and
# fill in your real Supabase credentials. NEVER commit the real
# secrets.toml to GitHub — keep it in .gitignore.
#
# On Streamlit Community Cloud: don't upload this file at all. Instead,
# go to your app → Settings → Secrets, and paste these two lines there.
# ─────────────────────────────────────────────────────────────────────────

SUPABASE_URL = "https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_KEY = "YOUR-ANON-PUBLIC-KEY"
